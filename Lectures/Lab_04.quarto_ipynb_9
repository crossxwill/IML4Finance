    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Interpreting the Best Model\n",
        "\n",
        "We select the best-performing model from the comparison results (by highest Test F1 score) and perform interpretability analysis on it."
      ],
      "id": "45ad4278"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: interpret-best-model-setup\n",
        "\n",
        "chosen_model_to_interpret = None\n",
        "chosen_model_name = None\n",
        "best_strategy = None\n",
        "pfi_df = None\n",
        "pdp_ice_sample_data = None\n",
        "pdp_features_to_plot = []\n",
        "categorical_for_pdp = []\n",
        "shap_sample_data = None\n",
        "shap_values_summary = None\n",
        "max_display_features = None\n",
        "top_shap_features = []\n",
        "\n",
        "# Dynamically select the best model from comparison_results and prepare the\n",
        "# artifacts needed for the numbered interpretation outputs below.\n",
        "if comparison_results:\n",
        "    summary_df = pd.DataFrame(comparison_results)\n",
        "    best_row = summary_df.loc[summary_df['Test F1 (Optimized)'].idxmax()]\n",
        "    best_strategy = best_row['Strategy']\n",
        "    print(f\"Best strategy by F1-score: {best_strategy}\")\n",
        "\n",
        "    model_registry = {}\n",
        "    for var_name, strategy_key, display_name in [\n",
        "        ('ag_model_s1', \"1. Ignore Class Imbalance\", \"Strategy 1 (Ignore Class Imbalance)\"),\n",
        "        ('ag_model_s2', \"2. Class Sensitive Evaluation\", \"Strategy 2 (Class-Sensitive)\"),\n",
        "        ('ag_model_s3', \"3. Cost Sensitive Learning\", \"Strategy 3 (Cost-Sensitive)\"),\n",
        "        ('ag_model_s4a', \"4a. RUS\", \"Strategy 4a (RUS)\"),\n",
        "        ('ag_model_s4b', \"4b. ROS\", \"Strategy 4b (ROS)\"),\n",
        "        ('ag_model_s4c', \"4c. SMOTE\", \"Strategy 4c (SMOTE)\"),\n",
        "        ('ag_model_s4d', \"4d. Hybrid (SMOTE+RUS)\", \"Strategy 4d (Hybrid)\"),\n",
        "    ]:\n",
        "        if var_name in locals() and locals()[var_name].is_fitted_:\n",
        "            model_registry[strategy_key] = (locals()[var_name], display_name)\n",
        "\n",
        "    if best_strategy in model_registry:\n",
        "        chosen_model_to_interpret, chosen_model_name = model_registry[best_strategy]\n",
        "    else:\n",
        "        print(f\"Best model ({best_strategy}) not available. Falling back to Strategy 2.\")\n",
        "        chosen_model_to_interpret = ag_model_s2\n",
        "        chosen_model_name = \"Strategy 2 (Class-Sensitive) - Fallback\"\n",
        "\n",
        "    print(f\"Interpreting: {chosen_model_name}\")\n",
        "\n",
        "    X_test_with_label = X_test.copy()\n",
        "    X_test_with_label['TX_FRAUD'] = y_test\n",
        "    pfi = chosen_model_to_interpret.predictor.feature_importance(data=X_test_with_label, silent=True)\n",
        "    pfi_df = pfi.reset_index().rename(columns={'index': 'feature', 0: 'importance'})\n",
        "\n",
        "    pdp_ice_sample_data = X_train.sample(min(1000, len(X_train)), random_state=2025)\n",
        "    try:\n",
        "        pdp_features = chosen_model_to_interpret.predictor.features()\n",
        "        if len(pdp_features) > 5:\n",
        "            pdp_features_to_plot = pfi_df['feature'].head(5).tolist()\n",
        "        else:\n",
        "            pdp_features_to_plot = pdp_features\n",
        "\n",
        "        cat_features_metadata = chosen_model_to_interpret.predictor.feature_metadata\n",
        "        categorical_for_pdp = [\n",
        "            feature_name for feature_name in pdp_features_to_plot\n",
        "            if cat_features_metadata.get_feature_type_raw(feature_name) == 'category'\n",
        "        ]\n",
        "    except Exception as e_pdp:\n",
        "        print(f\"Could not prepare PDP/ICE plots: {e_pdp}\")\n",
        "        pdp_features_to_plot = []\n",
        "        categorical_for_pdp = []\n",
        "\n",
        "    if len(X_test) > 200:\n",
        "        shap_sample_data = X_test.sample(200, random_state=2025)\n",
        "    else:\n",
        "        shap_sample_data = X_test\n",
        "\n",
        "    try:\n",
        "        shap_explainer = shap.Explainer(\n",
        "            lambda x: chosen_model_to_interpret.predict_proba(x)[:, 1],\n",
        "            shap_sample_data\n",
        "        )\n",
        "        shap_values_summary = shap_explainer(shap_sample_data)\n",
        "        max_display_features = min(10, shap_sample_data.shape[1])\n",
        "        top_shap_features = pfi_df['feature'].head(min(5, len(pfi_df))).tolist()\n",
        "\n",
        "        max_abs_shap = float(np.max(np.abs(shap_values_summary.values)))\n",
        "        if max_abs_shap < 1e-4:\n",
        "            print(\n",
        "                \"Note: the sampled SHAP values are numerically very small, so the beeswarm may appear tightly compressed around zero.\"\n",
