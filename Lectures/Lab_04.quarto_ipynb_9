      "source": [
        "#| label: tbl-logistic-rus-prior-correction-diagnostics\n",
        "#| tbl-cap: Diagnostics for logistic RUS prior correction\n",
        "\n",
        "%matplotlib inline\n",
        "\n",
        "def logit(p):\n",
        "    p = np.clip(p, 1e-12, 1 - 1e-12)\n",
        "    return np.log(p / (1 - p))\n",
        "\n",
        "def inverse_logit(z):\n",
        "    return 1 / (1 + np.exp(-z))\n",
        "\n",
        "# Example: map a logistic regression trained on the RUS data back to the\n",
        "# original non-resampled training-set class prior.\n",
        "# Use statsmodels GLM via the formula interface so the fit follows the\n",
        "# canonical unpenalized binomial IRLS routine for this intercept shift.\n",
        "rus_glm_data = X_train_rus.copy()\n",
        "rus_glm_data[target_label] = np.asarray(y_train_rus)\n",
        "logistic_formula = f\"{target_label} ~ {' + '.join(final_features)}\"\n",
        "logistic_rus = smf.glm(\n",
        "    formula=logistic_formula,\n",
        "    data=rus_glm_data,\n",
        "    family=sm.families.Binomial()\n",
        ").fit()\n",
        "\n",
        "prior_original = y_train.mean()\n",
        "prior_resampled = y_train_rus.mean()\n",
        "intercept_hat_resampled = logistic_rus.params[\"Intercept\"]\n",
        "\n",
        "linear_predictor_sampled_tuning = np.asarray(\n",
        "    logistic_rus.predict(X_tuning, which=\"linear\"),\n",
        "    dtype=float\n",
        ")\n",
        "linear_predictor_sampled = np.asarray(\n",
        "    logistic_rus.predict(X_test, which=\"linear\"),\n",
        "    dtype=float\n",
        ")\n",
        "raw_sampled_probs_tuning = inverse_logit(linear_predictor_sampled_tuning)\n",
        "raw_sampled_probs = inverse_logit(linear_predictor_sampled)\n",
        "\n",
        "prior_log_odds_shift = logit(prior_original) - logit(prior_resampled)\n",
        "intercept_hat_original_scale = intercept_hat_resampled + prior_log_odds_shift\n",
        "\n",
        "linear_predictor_original_tuning = linear_predictor_sampled_tuning + prior_log_odds_shift\n",
        "linear_predictor_original = linear_predictor_sampled + prior_log_odds_shift\n",
        "\n",
        "# Extract the sampled-data linear predictor directly from statsmodels so the\n",
        "# code mirrors the derivation: the correction is a constant shift in log-odds.\n",
        "constant_shift_range_tuning = np.ptp(\n",
        "    linear_predictor_original_tuning - linear_predictor_sampled_tuning\n",
        ")\n",
        "constant_shift_range_test = np.ptp(\n",
        "    linear_predictor_original - linear_predictor_sampled\n",
        ")\n",
        "\n",
        "prior_corrected_probs_tuning = inverse_logit(linear_predictor_original_tuning)\n",
        "prior_corrected_probs = inverse_logit(linear_predictor_original)\n",
        "\n",
        "display(pd.DataFrame({\n",
        "    \"prior_original\": [prior_original],\n",
        "    \"prior_resampled\": [prior_resampled],\n",
        "    \"intercept_hat_resampled\": [intercept_hat_resampled],\n",
        "    \"prior_log_odds_shift\": [prior_log_odds_shift],\n",
        "    \"intercept_hat_original_scale\": [intercept_hat_original_scale],\n",
        "    \"constant_shift_range_tuning\": [constant_shift_range_tuning],\n",
        "    \"constant_shift_range_test\": [constant_shift_range_test],\n",
        "    \"mean_raw_sampled_test_probability\": [raw_sampled_probs.mean()],\n",
        "    \"mean_prior_corrected_test_probability\": [prior_corrected_probs.mean()]\n",
        "}))"
