      "source": [
        "#| label: resampling-hybrid-prep\n",
        "\n",
        "minority_class_count_hybrid = y_train.value_counts().min()\n",
        "if minority_class_count_hybrid <= 1:\n",
        "    print(\"Minority class count is too low for SMOTE. Using original data as fallback.\")\n",
        "    X_train_hybrid, y_train_hybrid = X_train.copy(), y_train.copy()\n",
        "else:\n",
        "    k_neighbors_hybrid = min(5, max(1, minority_class_count_hybrid - 1))\n",
        "    smote_hybrid = SMOTE(random_state=2025, k_neighbors=k_neighbors_hybrid, sampling_strategy=0.5)\n",
        "    X_train_smote_temp, y_train_smote_temp = smote_hybrid.fit_resample(X_train, y_train)\n",
        "    rus_hybrid = RandomUnderSampler(random_state=2025, sampling_strategy=0.8)\n",
        "    X_train_hybrid, y_train_hybrid = rus_hybrid.fit_resample(X_train_smote_temp, y_train_smote_temp)\n",
        "\n",
        "print(f\"Hybrid training data shape: {X_train_hybrid.shape}\")\n",
        "print(f\"Hybrid target distribution:\\n{y_train_hybrid.value_counts(normalize=True)}\")"
