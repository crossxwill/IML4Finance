        "remove_ag_folder(model_folder_s1)\n",
        "\n",
        "predictor_args_s1 = {\n",
        "    'problem_type': 'binary',\n",
        "    'eval_metric': 'log_loss', \n",
        "    'path': model_folder_s1\n",
        "}\n",
        "\n",
