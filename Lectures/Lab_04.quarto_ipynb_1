      "source": [
        "### Hybrid: SMOTE + RUS\n",
        "\n",
        "First apply SMOTE to generate synthetic minority samples, then apply random undersampling to the majority class."
      ],
      "id": "308a7e51"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: resampling-hybrid-prep\n",
        "\n",
        "minority_class_count = y_train.value_counts().min()\n",
        "if minority_class_count <= 1:\n",
        "    print(\"Minority class count is too low for SMOTE. Using original data as fallback.\")\n",
        "    X_train_hybrid, y_train_hybrid = X_train.copy(), y_train.copy()\n",
        "else:\n",
        "    k_neighbors_hybrid = min(5, max(1, minority_class_count - 1))\n",
        "    # Use partial balancing: SMOTE to 0.5 (50% of majority), then RUS to 0.8 (80% majority-to-minority ratio).\n",
        "    # This avoids the extreme overfitting of full SMOTE and the information loss of full RUS.\n",
        "    smote_hybrid = SMOTE(random_state=2025, k_neighbors=k_neighbors_hybrid, sampling_strategy=0.5)\n",
        "    X_train_smote_temp, y_train_smote_temp = smote_hybrid.fit_resample(X_train, y_train)\n",
        "    rus_hybrid = RandomUnderSampler(random_state=2025, sampling_strategy=0.8)\n",
        "    X_train_hybrid, y_train_hybrid = rus_hybrid.fit_resample(X_train_smote_temp, y_train_smote_temp)\n",
        "    print(f\"Hybrid training data shape: {X_train_hybrid.shape}\")\n",
        "    print(f\"Hybrid target distribution:\\n{y_train_hybrid.value_counts(normalize=True)}\")"
      ],
      "id": "resampling-hybrid-prep",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: setup-autogluon-hybrid\n",
        "\n",
        "strategy_name_4d = \"4d. Hybrid (SMOTE+RUS)\"\n",
        "model_folder_s4d = \"./Lab04_ag_models_s4_hybrid\"\n",
