        "            'excluded_model_types': ['KNN'],\n",
        "            'presets': 'medium_quality',\n",
        "            'time_limit': 180}\n",
        "\n",
        "ag_wrapper_s1 = AutoGluonSklearnWrapper(\n",
        "    label=target_label,\n",
        "    predictor_args=predictor_args_s1,\n",
        "    fit_args=fit_args_s1,\n",
        "    n_jobs=num_jobs\n",
