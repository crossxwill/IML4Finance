      "source": [
        "cal_model_s3 = CalibratedClassifierCV(\n",
        "    estimator = ag_model_s3,\n",
        "    method='isotonic',\n",
        "    cv=\"prefit\" # Use the fitted model from ag_model\n",
        ")\n",
        "\n",
        "global_set_seed()\n",
        "\n",
        "cal_model_s3.fit(X = X_tuning,\n",
