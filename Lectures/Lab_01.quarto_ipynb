        "#| label: lab01-compute-wrapper-importance\n",
        "best_feature_importance_wrapper = (ag_model_wrapper_method\n",
        "                            .named_steps['autogluon']\n",
        "                            .predictor\n",
        "                            .feature_importance(\n",
        "                                    data = preprocessed_test_data_wrapper, \n",
